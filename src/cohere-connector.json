      "value": "={\"model\": (if rerankModel = \"custom\" then rerankModelCustom else rerankModel), \"query\": rerankQuery, \"documents\": rerankDocuments, \"top_n\": number(rerankTopN)}",
      "binding": {
        "type": "zeebe:input",
        "name": "body"
      },
      "condition": {
        "property": "operationId",
        "equals": "rerank"
      }
